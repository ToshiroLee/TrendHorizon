<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    .btn-custom {
      background-color: #ffcc33; /* Yellow button color */
      color: #333;
      border: none;
      border-radius: 25px;
      padding: 0.8rem 2rem;
      margin: 0.5rem;
      font-weight: bold;
      font-size: 1rem;
    }
    .btn-custom:hover {
      background-color: #e6b800;
      color: white; 
    }

    body {
      background-color: #93c5ee; /* Light blue background inspired by your Canva design */
      color: #333; /* Neutral text color */
      font-family: 'Arial', sans-serif;
    }

  .navbar {
    background: rgba(154, 103, 236, 0.8); /* Semi-transparent white */
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2); /* Soft shadow */
  }
  .navbar-brand img {
    margin: auto; /* Center the logo */
  }
  .nav-link {
    font-weight: bold;
    margin: 0 10px;
  }
</style>
  <title>TrendHorizon Store</title>
</head>
<body>
    <!-- Dropdown Navbar -->
    <nav class="navbar navbar-expand-lg">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">
          <img src="/images/logo.png" alt="TrendHorizon Logo"> TrendHorizon
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <% if (user) { %>
              <!-- Trends Dropdown -->
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  Trends
                </a>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="/shopping">All Investment Types</a></li>
                  <li><a class="dropdown-item" href="/shopping/stocks">Stocks</a></li>
                  <li><a class="dropdown-item" href="/shopping/crypto">Crypto Currencies</a></li>
                </ul>
              </li>
              
              <!-- Compare Trends Link -->
              <li class="nav-item">
                <a class="nav-link" href="/chart">Compare Trends</a>
              </li>
              
              <!-- Account Dropdown -->
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  Account
                </a>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="/logout">Logout</a></li>
                </ul>
              </li>
            <% } else { %>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Welcome Section -->
    <div class="container" style="height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
        <% if (user) { %>
          <h1 style="font-size: 5rem; font-weight: bold; text-align: center; margin-bottom: 2rem; color: #333;">Welcome to TrendHorizon!</h1>
          <p style="font-size: 1.5rem; text-align: center; color: #555;">To navigate market trends, use the navbar to get started</p>
          <p style="font-size: 1.5rem; text-align: center; color: #555;">Logged in as <%= user.username %> (<%= user.role %>)</p>
        <% } else { %>
          <h1 style="font-size: 5rem; font-weight: bold; text-align: center; margin-bottom: 2rem; color: #333;">Welcome to TrendHorizon!</h1>
          <p style="font-size: 1.5rem; text-align: center; color: #555;">Come Sign Up/Sign In to get started!</p>
          <div>
            <a href="/register" class="btn btn-custom">Sign Up</a>
            <a href="/login" class="btn btn-custom">Sign In</a>
          </div>
        <% } %>
    </div>
</body>
</html>
