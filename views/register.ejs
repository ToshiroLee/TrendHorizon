<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof isUserManagement !== 'undefined' && isUserManagement ? 'Add User' : 'Register' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        .btn-custom {
            background-color: #ffcc33;
            color: #333;
            border: none;
            border-radius: 25px;
            padding: 0.8rem 2rem;
            margin: 0.5rem;
            font-weight: bold;
            font-size: 1rem;
        }
        .btn-custom:hover {
            background-color: #e6b800;
            color: white;
        }
        body {
            background-color: #93c5ee;
            color: #333;
            font-family: 'Arial', sans-serif;
        }
        .navbar {
            background: rgba(154, 103, 236, 0.8);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        }
        .main-container {
            background-color: white;
            border-radius: 20px;
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
            padding: 2rem;
            margin-top: 2rem;
        }
        .form-control, .form-select {
            border-radius: 15px;
            border: 2px solid #e9ecef;
            padding: 0.75rem 1rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: #7a67ec;
            box-shadow: 0 0 0 0.2rem rgba(122, 103, 236, 0.25);
        }
    </style>
</head>
<body>
    <% if (typeof isUserManagement !== 'undefined' && isUserManagement) { %>
        <%- include ('partials/navbar.ejs') %>
    <% } %>
    
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <div class="main-container">
                    <div class="text-center mb-4">
                        <h2 style="color: #7a67ec;">
                            <%= typeof isUserManagement !== 'undefined' && isUserManagement ? 'Add New User' : 'Register' %>
                        </h2>
                        <p class="text-muted">
                            <%= typeof isUserManagement !== 'undefined' && isUserManagement ? 'Create a new user account' : 'Create your account' %>
                        </p>
                    </div>

                    <% if (messages && messages.length > 0) { %>
                        <div class="alert alert-danger alert-dismissible fade show">
                            <% messages.forEach(function(message) { %>
                                <%= message %><br>
                            <% }); %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>

                    <form action="<%= typeof isUserManagement !== 'undefined' && isUserManagement ? '/users/add' : '/register' %>" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="username" class="form-label">Username</label>
                                <input type="text" id="username" name="username" class="form-control" required 
                                       value="<%= (formData && formData.username) || '' %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" id="email" name="email" class="form-control" required 
                                       value="<%= (formData && formData.email) || '' %>">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" id="password" name="password" class="form-control" required>
                            <div class="form-text">Password must be at least 6 characters long.</div>
                        </div>

                        <div class="mb-3">
                            <label for="address" class="form-label">Address</label>
                            <textarea class="form-control" id="address" name="address" rows="2" required><%= (formData && formData.address) || '' %></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="contact" class="form-label">Contact Number</label>
                                <input type="tel" id="contact" name="contact" class="form-control" required 
                                       value="<%= (formData && formData.contact) || '' %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="role" class="form-label">Role</label>
                                <select id="role" name="role" class="form-select" required>
                                    <option value="user" <%= (formData && formData.role === 'user') || (!formData) ? 'selected' : '' %>>User</option>
                                    <option value="admin" <%= (formData && formData.role === 'admin') ? 'selected' : '' %>>Admin</option>
                                </select>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <% if (typeof isUserManagement !== 'undefined' && isUserManagement) { %>
                                <a href="/users" class="btn btn-secondary me-2">Cancel</a>
                            <% } %>
                            <button type="submit" class="btn btn-custom">
                                <%= typeof isUserManagement !== 'undefined' && isUserManagement ? 'Add User' : 'Register' %>
                            </button>
                        </div>
                    </form>

                    <% if (typeof isUserManagement === 'undefined' || !isUserManagement) { %>
                        <div class="text-center mt-3">
                            <p>Already have an account? <a href="/login">Login here</a></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
