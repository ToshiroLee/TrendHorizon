<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <style>
      .btn-custom {
        background-color: #ffcc33; /* Yellow button color */
        color: #333;
        border: none;
        border-radius: 25px;
        padding: 0.8rem 2rem;
        margin: 0.5rem;
        font-weight: bold;
        font-size: 1rem;
      }
      .btn-custom:hover {
        background-color: #e6b800;
        color: white; 
      }
  
      body {
        background-color: #93c5ee; /* Light blue background inspired by your Canva design */
        color: #333; /* Neutral text color */
        font-family: 'Arial', sans-serif;
      }
  
    .navbar {
      background: rgba(154, 103, 236, 0.8); /* Semi-transparent white */
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2); /* Soft shadow */
    }
    .navbar-brand img {
      margin: auto; /* Center the logo */
    }
    .nav-link {
      font-weight: bold;
      margin: 0 10px;
    }
  </style>
    <title>TrendHorizon Store</title>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
          <img src="/images/logo.png" alt="TrendHorizon Logo"> TrendHorizon
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <!-- Trends Dropdown -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Trends
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/shopping">All Investment Types</a></li>
                <li><a class="dropdown-item" href="/shopping/stocks">Stocks</a></li>
                <li><a class="dropdown-item" href="/shopping/crypto">Crypto Currencies</a></li>
              </ul>
            </li>
            
            <!-- Compare Trends Link -->
            <li class="nav-item">
              <a class="nav-link" href="/chart">Compare Trends</a>
            </li>
            
            <!-- Account Dropdown -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Account
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container">
        <br>
        <div class="text-center"><h2>Update Trend</h2></div>
        <br>
        <div class="text-center">
          <% if (trend) { %> 
            <!-- Display current trend image -->
            <div class="mb-4">
              <h4>Current Trend Image</h4>
              <% if (trend.image) { %>
                <img src="/images/<%= trend.image %>" alt="<%= trend.trendName %>" class="img-fluid" style="max-width: 300px; max-height: 200px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
              <% } else { %>
                <p class="text-muted">No image available</p>
              <% } %>
            </div>
            
            <form action="/trend/<%= trend.trendId %>/update" method="POST" enctype="multipart/form-data">
                <label for="name">Trend Name:</label><br>
                <input type="text" id="name" name="name" value="<%= trend.trendName %>" required><br><br>

                <label for="description">Description:</label><br>
                <textarea id="description" name="description" rows="3" required><%= trend.description %></textarea><br><br>

                <!-- Image upload section -->
                <div class="mb-3">
                    <label for="image" class="form-label"><strong>Change Trend Image:</strong></label><br>
                    <input type="file" id="image" name="image" class="form-control" accept="image/*" style="max-width: 400px; margin: 0 auto;"><br>
                    <small class="text-muted">Choose a new image file to replace the current one (optional)</small><br><br>
                </div>

                <button type="submit" class="btn btn-primary">Update Trend</button>
            </form>
          <% } else { %>
            <p>No trend found.</p>
          <% } %>
        </div>
    </div>
</body>
</html>